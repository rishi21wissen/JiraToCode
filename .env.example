# =========================================
# JiraToCode AI — Environment Configuration
# =========================================

# Google Gemini API Key (REQUIRED for code generation and PR review)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Server port (default: 3000)
PORT=3000

# ---- GitHub Probot Settings (Optional — only for github-agent.js) ----
# APP_ID=
# WEBHOOK_SECRET=development
# WEBHOOK_PROXY_URL=
# PRIVATE_KEY=

# ---- Git Manager Persona (Required for auto PR creation) ----
# Personal Access Token with 'repo' scope
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Your GitHub username or organisation name
GITHUB_OWNER=

# The repository name (must match the GitHub repo exactly)
GITHUB_REPO=
